<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.input.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.naloga1_3.HelloController">

  <top>
    <VBox>
      <children>
        <MenuBar>
          <menus>
            <Menu mnemonicParsing="true" text="_Datoteke">
              <items>
                <MenuItem fx:id="odpriMenuItem" onAction="#odpriRA" text="_Odpri">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="O" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator></MenuItem>
                        <MenuItem onAction="#pobrisiRA" text="_Pobrisi">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="C" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator></MenuItem>
                        <MenuItem onAction="#izhodRA" text="_Izhod">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="Q" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator></MenuItem>
              </items>
            </Menu>

            <Menu text="_Uredi">
              <items>
                <CheckMenuItem fx:id="imeMenuItem" onAction="#urediImeRA" text="_Ime udelezenca" />
                <CheckMenuItem fx:id="tipMenuItem" onAction="#urediTipRA" text="_Tip vadbe" />
                <CheckMenuItem fx:id="terminMenuItem" onAction="#urediTerminRA" text="_Termin vadbe" />
              </items>
            </Menu>

            <Menu text="_Pogled">
              <items>
                <MenuItem fx:id="izpisiVseMenuItem" onAction="#izpisiVseRA" text="_Izpisi vse" />
              </items>
            </Menu>

            <Menu text="_Pomoc" />
          </menus>
        </MenuBar>

        <ToolBar>
          <items>
            <Button fx:id="odpriButton" onAction="#odpriRA" text="Odpri" />
            <Button fx:id="pobrisiButton" onAction="#pobrisiRA" text="Pobrisi" />
            <Button fx:id="izhodButton" onAction="#izhodRA" text="Izhod" />
            <Separator orientation="VERTICAL" />
            <Button fx:id="izpisiVseButton" onAction="#izpisiVseRA" text="Izpisi vse" />
          </items>
        </ToolBar>
      </children>
    </VBox>
  </top>

  <center>
    <HBox spacing="20.0">
      <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>

      <children>
        <VBox prefWidth="380.0" spacing="14.0">

          <children>

            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
              </columnConstraints>

              <children>
                <Label text="Ime udelezenca:" />
                <TextField fx:id="imeField" disable="true" GridPane.columnIndex="1" />

                <Label text="Tip vadbe:" GridPane.rowIndex="1" />
                <TextField fx:id="tipField" disable="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Termin vadbe:" GridPane.rowIndex="2" />
                <TextField fx:id="terminField" disable="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
              </children>
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
            </GridPane>

            <HBox alignment="CENTER" spacing="50.0">
              <children>
                <RadioButton fx:id="prijavaRadio" selected="true" text="Prijava">
                  <toggleGroup>
                    <ToggleGroup fx:id="akcijaToggleGroup" />
                  </toggleGroup>
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                </RadioButton>

                <RadioButton fx:id="odjavaRadio" text="Odjava" toggleGroup="$akcijaToggleGroup" />
                <RadioButton fx:id="spremeniRadio" text="Sprememba" toggleGroup="$akcijaToggleGroup" />
              </children>
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
            </HBox>

            <HBox alignment="CENTER_RIGHT">
              <children>
                <Button fx:id="izvediButton" onAction="#izvediAkcijoRA" prefWidth="110.0" scaleX="1.2" scaleY="1.2" text="Izvedi akcijo">
                           <HBox.margin>
                              <Insets right="10.0" top="10.0" />
                           </HBox.margin>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding></Button>
              </children>
            </HBox>

            <GridPane hgap="12.0" vgap="12.0">
              <columnConstraints>
                <ColumnConstraints prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
              </columnConstraints>

              <children>
                <Label text="Vnos:" />
                <ComboBox fx:id="rezervacijeCombo" onAction="#comboBoxChanged" prefWidth="220.0" GridPane.columnIndex="1" />

                <Label text="Rezervacija na poziciji:" GridPane.rowIndex="1" />
                <Spinner fx:id="pozicijaSpinner" prefWidth="220.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Sporocilo:" GridPane.rowIndex="2" />
                <Label fx:id="sporociloLabel" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
              </children>
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                     <VBox.margin>
                        <Insets top="30.0" />
                     </VBox.margin>
            </GridPane>

          </children>
        </VBox>

        <TextArea fx:id="izpisArea" prefWidth="350.0" HBox.hgrow="ALWAYS" />

      </children>
    </HBox>
  </center>

  <bottom>
    <HBox spacing="10.0">
      <padding>
        <Insets bottom="6.0" left="10.0" right="10.0" top="6.0" />
      </padding>
      <children>
        <Label fx:id="Status" text="Status:" />
        <Label fx:id="statusLabel" text="..." />
      </children>
    </HBox>
  </bottom>

</BorderPane>
